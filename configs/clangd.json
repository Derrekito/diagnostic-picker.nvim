{
  "provider": "clangd",
  "lsp_name": "clangd",
  "filetypes": ["c", "cpp", "h", "hpp"],
  "sections": [
    {
      "id": "cpp_standard",
      "title": "C++ Standard",
      "kind": "radio",
      "apply_to": "compile_flags",
      "flag_prefix": "-std=",
      "items": [
        { "name": "c++98",  "desc": "C++98" },
        { "name": "c++03",  "desc": "C++03" },
        { "name": "c++11",  "desc": "C++11" },
        { "name": "c++14",  "desc": "C++14" },
        { "name": "c++17",  "desc": "C++17", "default": true },
        { "name": "c++20",  "desc": "C++20" },
        { "name": "c++23",  "desc": "C++23" },
        { "name": "c++26",  "desc": "C++26" }
      ]
    },
    {
      "id": "compiler_flags",
      "title": "Compiler Flags",
      "kind": "toggle",
      "apply_to": "compile_flags",
      "items": [
        { "name": "-Wall",                   "desc": "Common warnings",              "default": false },
        { "name": "-Wextra",                 "desc": "Extra warnings",               "default": false },
        { "name": "-Wpedantic",              "desc": "ISO conformance",              "default": false },
        { "name": "-Weverything",            "desc": "All clang warnings (verbose)",  "default": false },
        { "name": "-Wshadow",                "desc": "Variable shadowing",           "default": false },
        { "name": "-Wnon-virtual-dtor",      "desc": "Non-virtual destructor",       "default": false },
        { "name": "-Wold-style-cast",        "desc": "C-style casts",               "default": false },
        { "name": "-Wcast-align",            "desc": "Alignment-increasing casts",   "default": false },
        { "name": "-Wunused",                "desc": "Unused entities",              "default": false },
        { "name": "-Woverloaded-virtual",    "desc": "Hidden virtual overloads",     "default": false },
        { "name": "-Wconversion",            "desc": "Implicit conversions",         "default": false },
        { "name": "-Wsign-conversion",       "desc": "Sign conversions",             "default": false },
        { "name": "-Wmisleading-indentation","desc": "Misleading indentation",       "default": false },
        { "name": "-Wnull-dereference",      "desc": "Null dereference",             "default": false },
        { "name": "-Wdouble-promotion",      "desc": "float->double promotion",      "default": false },
        { "name": "-Wformat=2",              "desc": "Strict format strings",        "default": false },
        { "name": "-Wimplicit-fallthrough",  "desc": "Switch fallthrough",           "default": false },
        { "name": "-Wlifetime",              "desc": "Lifetime/dangling pointers",   "default": false }
      ]
    },
    {
      "id": "clang_tidy",
      "title": "Clang-Tidy Categories",
      "kind": "category",
      "apply_to": "clang_tidy",
      "expandable": true,
      "items": [
        { "name": "modernize-*",         "desc": "Modern C++",            "default": false },
        { "name": "readability-*",       "desc": "Readability",           "default": false },
        { "name": "performance-*",       "desc": "Performance",           "default": false },
        { "name": "bugprone-*",          "desc": "Bug-prone patterns",    "default": false },
        { "name": "cppcoreguidelines-*", "desc": "Core Guidelines",       "default": false },
        { "name": "clang-analyzer-*",    "desc": "Static analyzer",       "default": false },
        { "name": "misc-*",             "desc": "Miscellaneous",          "default": false },
        { "name": "cert-*",             "desc": "CERT",                   "default": false },
        { "name": "google-*",           "desc": "Google style",           "default": false },
        { "name": "hicpp-*",            "desc": "High Integrity C++",     "default": false },
        { "name": "portability-*",       "desc": "Portability",           "default": false },
        { "name": "concurrency-*",       "desc": "Concurrency",           "default": false },
        { "name": "llvm-*",             "desc": "LLVM",                   "default": false },
        { "name": "abseil-*",           "desc": "Abseil",                 "default": false },
        { "name": "boost-*",            "desc": "Boost",                  "default": false },
        { "name": "android-*",          "desc": "Android",                "default": false },
        { "name": "fuchsia-*",          "desc": "Fuchsia",                "default": false },
        { "name": "linuxkernel-must-check-errs", "desc": "Linux Kernel",  "default": false },
        { "name": "mpi-*",              "desc": "MPI",                    "default": false },
        { "name": "openmp-*",           "desc": "OpenMP",                 "default": false },
        { "name": "zircon-*",           "desc": "Zircon",                 "default": false }
      ]
    }
  ]
}
